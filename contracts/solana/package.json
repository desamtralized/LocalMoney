{
  "name": "localmoney-solana",
  "version": "0.1.0",
  "description": "LocalMoney Protocol - Solana Implementation",
  "main": "index.js",
  "scripts": {
    "test": "ts-mocha -p ./tsconfig.json -t 1000000 tests/**/*.ts",
    "test:anchor": "ts-mocha -p ./tsconfig.json -t 1000000 tests/anchor-minimal.ts",
    "test:unit": "anchor test tests/**/*.ts",
    "test:integration": "anchor test tests/integration/*.ts",
    "test:full-lifecycle": "anchor test tests/integration/full-lifecycle.test.ts",
    "test:direct": "ts-mocha -p ./tsconfig.json -t 1000000",
    "test:direct:full-lifecycle": "npm run test:direct -- tests/integration/full-lifecycle.test.ts",
    "test:direct:integration": "npm run test:direct -- tests/integration/*.ts",
    "test:direct:unit": "npm run test:direct -- tests/*.test.ts",
    "test:direct:all": "npm run test:direct -- \"tests/**/*.test.ts\"",
    "test:direct:hub": "npm run test:direct -- tests/hub.test.ts",
    "setup-test-env": "ts-node scripts/setup-test-env.ts",
    "setup-test-env:no-build": "ts-node scripts/setup-test-env.ts --no-build",
    "run-integration-tests": "npm run setup-test-env && npm run test:direct:integration",
    "run-unit-tests": "npm run setup-test-env && npm run test:direct:unit",
    "run-hub-tests": "npm run setup-test-env && npm run test:direct:hub",
    "run-full-lifecycle": "npm run setup-test-env && npm run test:direct:full-lifecycle",
    "run-full-lifecycle:no-build": "npm run setup-test-env:no-build && npm run test:direct:full-lifecycle",
    "run-all-tests": "npm run setup-test-env && npm run test:direct:all",
    "run-all-tests:no-build": "npm run setup-test-env:no-build && npm run test:direct:all",
    "build": "anchor build",
    "deploy": "anchor deploy",
    "lint": "eslint . --ext .ts"
  },
  "keywords": [
    "solana",
    "anchor",
    "blockchain",
    "localmoney"
  ],
  "author": "LocalDAO",
  "license": "MIT",
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/spl-token": "^0.3.7",
    "@solana/web3.js": "^1.73.0",
    "borsh": "^2.0.0"
  },
  "devDependencies": {
    "@types/chai": "^4.3.4",
    "@types/mocha": "^10.0.1",
    "@types/node": "^18.11.18",
    "chai": "^4.3.7",
    "dotenv": "^16.5.0",
    "mocha": "^10.2.0",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^4.9.4"
  }
}
