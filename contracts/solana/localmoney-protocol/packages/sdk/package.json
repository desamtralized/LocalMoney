{
  "name": "@localmoney/solana-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for LocalMoney Solana Protocol",
  "main": "dist/simple-index.js",
  "types": "dist/simple-index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "ts-node tests/e2e-integration.test.ts",
    "test:watch": "nodemon --exec ts-node tests/e2e-integration.test.ts",
    "test:performance": "ts-node tests/performance-test.ts",
    "test:scenarios": "ts-node tests/real-world-scenario.test.ts",
    "test:all": "npm run test && npm run test:performance && npm run test:scenarios"
  },
  "keywords": [
    "solana",
    "anchor",
    "p2p",
    "trading",
    "sdk"
  ],
  "license": "ISC",
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/spl-token": "^0.4.13",
    "@solana/web3.js": "^1.98.2",
    "bn.js": "^5.2.1"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.0",
    "@types/node": "^20.19.9",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/web3.js": "^1.98.2"
  }
}
