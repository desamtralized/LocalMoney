## Common Test Patterns

### Setup Helper
```typescript
async function setupTestEnvironment() {
  const user = Keypair.generate();
  await airdrop(user.publicKey, 10 * LAMPORTS_PER_SOL);
  
  const [profilePda] = PublicKey.findProgramAddressSync(
    [Buffer.from("profile"), user.publicKey.toBuffer()],
    program.programId
  );
  
  return { user, profilePda };
}
```

### State Snapshot
```typescript
async function captureState(program, accounts) {
  const state = {};
  for (const [name, address] of Object.entries(accounts)) {
    state[name] = await program.account[name].fetch(address);
  }
  return state;
}
```

### Time Advancement
```typescript
async function advanceTime(seconds: number) {
  // For time-based tests on localnet
  const slot = await program.provider.connection.getSlot();
  await program.provider.connection.confirmTransaction(
    await program.provider.connection.requestAirdrop(
      Keypair.generate().publicKey,
      0
    )
  );
}
```

## Debugging Tests

### Logging
```typescript
// Add detailed logging
console.log("Account state:", await program.account.profile.fetch(profilePda));
console.log("Transaction signature:", signature);
```

### Account Inspection
```typescript
// Check account exists and has correct data
const accountInfo = await program.provider.connection.getAccountInfo(profilePda);
console.log("Account owner:", accountInfo?.owner.toString());
console.log("Account data length:", accountInfo?.data.length);
```

### Transaction Analysis
```typescript
// Get detailed transaction info
const tx = await program.provider.connection.getTransaction(signature, {
  commitment: "confirmed",
  maxSupportedTransactionVersion: 0
});
console.log("Transaction logs:", tx?.meta?.logMessages);
```

